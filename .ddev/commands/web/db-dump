#!/bin/bash
## Description: Snapshot der lokalen DB als SQL-Dump (mit Auto-Naming, Wrapper um wp db export)
## Usage: db-dump [filename]
## Example: ddev db-dump backup-vor-migration.sql

set -e

FILENAME="${1:-${DDEV_PROJECT}-$(date +%Y-%m-%d-%H%M).sql}"

echo "==> Exportiere DB nach $FILENAME..."
wp db export "$FILENAME" --add-drop-table --quiet

echo "✅ Export fertig: $FILENAME"
ls -lh "$FILENAME"
