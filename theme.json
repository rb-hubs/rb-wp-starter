{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "1280px",
      "wideSize": "1440px"
    },
    "color": {
      "background": true,
      "text": true,
      "link": true,
      "customGradient": false,
      "defaultPalette": false,
      "defaultGradients": false,
      "defaultDuotone": false,
      "palette": [
        { "slug": "{{SITE_PREFIX}}-primary",   "name": "Primary",        "color": "#1B2A6B" },
        { "slug": "{{SITE_PREFIX}}-primary-dk","name": "Primary Dark",   "color": "#0F1842" },
        { "slug": "{{SITE_PREFIX}}-accent",    "name": "Accent",         "color": "#D42027" },
        { "slug": "{{SITE_PREFIX}}-accent-dk", "name": "Accent Dark",    "color": "#B31A20" },
        { "slug": "{{SITE_PREFIX}}-bg",        "name": "Background",     "color": "#FAF8F5" },
        { "slug": "{{SITE_PREFIX}}-surface",   "name": "Surface",        "color": "#EFEAE1" },
        { "slug": "{{SITE_PREFIX}}-line",      "name": "Line",           "color": "#E5DED0" },
        { "slug": "{{SITE_PREFIX}}-gray",      "name": "Gray",           "color": "#6B6660" },
        { "slug": "{{SITE_PREFIX}}-ink",       "name": "Ink",            "color": "#32302D" },
        { "slug": "{{SITE_PREFIX}}-white",     "name": "White",          "color": "#FFFFFF" },
        { "slug": "{{SITE_PREFIX}}-black",     "name": "Black",          "color": "#000000" }
      ]
    },
    "typography": {
      "dropCap": false,
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "lineHeight": true,
      "textDecoration": true,
      "textTransform": true,
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "sans",
          "name": "Sans",
          "fontFamily": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "name": "XS",    "size": "0.75rem",  "fluid": false },
        { "slug": "sm",   "name": "S",     "size": "0.875rem", "fluid": false },
        { "slug": "base", "name": "Basis", "size": "1rem",     "fluid": false },
        { "slug": "lg",   "name": "L",     "size": "1.125rem", "fluid": false },
        { "slug": "xl",   "name": "XL",    "size": "1.25rem",  "fluid": false },
        { "slug": "2xl",  "name": "2XL",   "size": "clamp(1.375rem, 1.2rem + 0.5vw, 1.5rem)" },
        { "slug": "3xl",  "name": "3XL",   "size": "clamp(1.625rem, 1.4rem + 0.8vw, 1.875rem)" },
        { "slug": "4xl",  "name": "4XL",   "size": "clamp(1.875rem, 1.6rem + 1.2vw, 2.25rem)" },
        { "slug": "5xl",  "name": "5XL",   "size": "clamp(2.25rem, 1.8rem + 2vw, 3rem)" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "padding": true,
      "margin": true,
      "blockGap": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--{{SITE_PREFIX}}-bg)",
      "text": "var(--wp--preset--color--{{SITE_PREFIX}}-ink)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--{{SITE_PREFIX}}-primary)"
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
